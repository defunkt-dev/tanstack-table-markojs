{
  "name": "marko-table",
  "version": "0.1.0",
  "description": "Marko 6 adapter for @tanstack/table-core — SSR, CSR, and virtualized tables with full resumability support",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/marko-table"
  },
  "keywords": [
    "marko",
    "tanstack",
    "table",
    "datagrid",
    "ssr",
    "resumability"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck && npm run lint && npm run test"
  },
  "peerDependencies": {
    "@tanstack/table-core": ">=8.0.0",
    "@tanstack/virtual-core": ">=3.0.0",
    "marko": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/virtual-core": {
      "optional": true
    }
  },
  "dependencies": {
    "@tanstack/table-core": ">=8.0.0",
    "happy-dom": "^20.8.9"
  },
  "devDependencies": {
    "@tanstack/virtual-core": "^3.13.23",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "happy-dom": "^16.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
